# Copy this file to .env and fill in your secrets.
# Never commit .env to git.

# OpenRouter API key — required for answer generation in the Streamlit demo
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Anthropic Claude API key (for Phase 1 generation)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (alternative LLM provider)
OPENAI_API_KEY=sk-...

# Optional: local Ollama endpoint
OLLAMA_BASE_URL=http://localhost:11434/v1
